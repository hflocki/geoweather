#Regen (Vorlage von https://github.com/stoppegp/ha-dwd-precipitation-forecast)
  - type: custom:mushroom-template-card
    icon: mdi:weather-rainy
    color: |-
      {% if states(entity) | float(0) > 0 %}
      blue
      {% else %}
      grey
      {% endif %}
    features_position: bottom
    entity: sensor.regenvorhersage
    multiline_secondary: false
    primary: |2-
          {% set next_start = state_attr(entity, 'next_start') %}
          {% set next_end = state_attr(entity, 'next_end') %}
          {% set next_length = state_attr(entity, 'next_length') %}

          {# 2. Prüfen, ob Regen in Sicht ist #}
          {% if next_start is not none and next_start not in ['unknown', 'unavailable'] %}
            
            {% set start_ts = next_start | as_timestamp(0) %}
            {% set now_ts = now() | as_timestamp %}

            {% if (start_ts > now_ts) %}
              {# FALL: Regen beginnt in der Zukunft #}
              {% set diff_min = ((start_ts - now_ts) / 60) | int %}
              
              {% if next_length is not none and next_length | int(0) > 0 %}
                In {{ diff_min }} Min. regnet es für {{ next_length | int }} Min.
              {% else %}
                In {{ diff_min }} Min. beginnt es zu regnen.
              {% endif %}
              
            {% elif (next_end is not none and next_end not in ['unknown', 'unavailable']) %}
              {# FALL: Es regnet bereits, Ende ist bekannt #}
              {% set end_ts = next_end | as_timestamp(0) %}
              {% if end_ts > now_ts %}
                 {% set rest_min = ((end_ts - now_ts) / 60) | int %}
                 Es regnet noch für {{ rest_min }} Minuten.
              {% else %}
                 Der Regen hört gerade auf.
              {% endif %}
              
            {% else %}
              {# FALL: Es regnet bereits, Ende unbekannt (Dauerregen) #}
              Es regnet aktuell (Dauerregen).
            {% endif %}

          {% else %}
            Kein Regen in den nächsten 2 Stunden.
          {% endif %}
    card_mod:
      style: |
        {% set entity = 'sensor.regenvorhersage' %}
        ha-card {
          background-image: linear-gradient(90deg{% set entity = entity %}{% set duration = state_attr(entity, 'forecast').keys() | last | as_timestamp - now() | as_timestamp %}{% set hue_min = 200 %}{% set hue_max = 300 %}{% set prec_max = 20 %}{% for x, y in state_attr(entity, 'forecast').items() %}{% set pos = ((x | as_timestamp - (now() | as_timestamp))/duration*100) | round %}{% set hsl_h = (y/prec_max*(hue_max-hue_min)+hue_min)|round %}{% set hsl_l = 50 if y > 0 else 100 %}{% set hsl_alpha = 0.5 if y > 0 else 0 %}{% if pos >= -4 %}, hsla({{hsl_h}}, 100%, {{hsl_l}}%, {{hsl_alpha}}) {{ max(pos,0) }}%{% endif %}{% endfor %});
        }

